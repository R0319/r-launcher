# バックエンドAPI（EC2）
API_BASE_URL=http://localhost:3000

# Discord OAuth（Client ID はランチャーに埋め込んでも問題ない公開情報。
# Client Secret は絶対にここに書かず、サーバー側 .env にのみ置く）
DISCORD_CLIENT_ID=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
DISCORD_OAUTH_SCOPE=identify

# Minecraftサーバー（Playボタン押下時にサーバーリストへ自動入力）
MC_SERVER_HOST=52.194.80.48
MC_SERVER_PORT=25565

# 起動するMinecraft/NeoForgeバージョン
MC_VERSION=1.21.1
NEOFORGE_VERSION=latest
