# サーバー設定
PORT=3000
HOST=0.0.0.0

# DB ドライバ: file=ローカル開発(JSON保存, MariaDB不要) / mysql=本番(EC2)
DB_DRIVER=mysql

# MariaDB（DB_DRIVER=mysql のときのみ使用）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=r_launcher
DB_PASSWORD=changeme
DB_NAME=r_launcher

# MOD配信ディレクトリ（required/ client/ server/ manifest.json を格納）
MODS_DIR=./mods_store

# Discord OAuth（Discord Developer Portalで作成したアプリの値。シークレットはこのサーバーだけが持つ）
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# /verify で発行するトークンの署名鍵（ランダムな長い文字列に変更すること）
VERIFY_TOKEN_SECRET=changeme-random-secret

# 管理者の Minecraft UUID（カンマ区切りで複数可）。ここに載っている本人だけが
# ランチャーの管理画面から MOD をアップロード/削除できる。ハイフン有無は問わない。
ADMIN_UUIDS=
